<ci:RuleSettingsControlBase
    x:Class="YcyzClass.Controls.RuleSettingsControls.CurrentSubjectRuleSettingsControl"
    x:TypeArguments="rules:CurrentSubjectRuleSettings"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:YcyzClass.Controls.RuleSettingsControls"
    xmlns:ci="http://ycyzclass.tech/schemas/xaml/core"
    xmlns:rules="clr-namespace:YcyzClass.Models.Rules"
    mc:Ignorable="d" 
    d:DesignHeight="450" d:DesignWidth="800">
    <Grid DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:CurrentSubjectRuleSettingsControl}}">
        <ComboBox ItemsSource="{Binding ProfileSettingsViewModel.Subjects.List}"
                  SelectedValue="{Binding Settings.SubjectId}"
                  SelectedValueBinding="{Binding Key}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Value.Name}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
    </Grid>
</ci:RuleSettingsControlBase>
