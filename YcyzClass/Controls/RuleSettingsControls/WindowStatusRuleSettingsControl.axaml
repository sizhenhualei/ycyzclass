<ci:RuleSettingsControlBase
    x:TypeArguments="rules:WindowStatusRuleSettings"
    x:Class="YcyzClass.Controls.RuleSettingsControls.WindowStatusRuleSettingsControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:YcyzClass.Controls.RuleSettingsControls"
    xmlns:ci="http://ycyzclass.tech/schemas/xaml/core"
    xmlns:rules="clr-namespace:YcyzClass.Models.Rules"
    mc:Ignorable="d" 
    d:DesignHeight="450" d:DesignWidth="800">
    <Grid DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:WindowStatusRuleSettingsControl}}">
        <ComboBox SelectedIndex="{Binding Settings.State}"
                  >
            <ComboBoxItem>
                正常
            </ComboBoxItem>
            <ComboBoxItem>
                最大化
            </ComboBoxItem>
            <ComboBoxItem>
                最小化
            </ComboBoxItem>
            <ComboBoxItem>
                全屏
            </ComboBoxItem>
        </ComboBox>
    </Grid>
</ci:RuleSettingsControlBase>
