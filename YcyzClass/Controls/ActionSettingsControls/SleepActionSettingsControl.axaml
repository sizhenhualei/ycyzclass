<ci:ActionSettingsControlBase x:Class="YcyzClass.Controls.ActionSettingsControls.SleepActionSettingsControl"
                              x:TypeArguments="actionSettings:SleepActionSettings"
                              d:DataContext="{d:DesignInstance Type=local:SleepActionSettingsControl}"
                              xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:ci="http://ycyzclass.tech/schemas/xaml/core"
                              xmlns:local="clr-namespace:YcyzClass.Controls.ActionSettingsControls"
                              xmlns:actionSettings="clr-namespace:YcyzClass.Models.Actions">
    <Panel>
        <ci:Field Suffix="秒" HorizontalAlignment="Left">
            <NumericUpDown MinWidth="147"
                           Minimum="0"
                           Value="{Binding Settings.Value, Converter={x:Static ci:NotNaNConverter.Instance}}" />
        </ci:Field>
    </Panel>
</ci:ActionSettingsControlBase>
