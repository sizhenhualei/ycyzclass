<ci:TriggerSettingsControlBase x:Class="YcyzClass.Controls.TriggerSettingsControls.SignalTriggerSettingsControl"
                               x:TypeArguments="triggers:SignalTriggerSettings"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:YcyzClass.Controls.TriggerSettingsControls"
             xmlns:ci="http://ycyzclass.tech/schemas/xaml/core"
             xmlns:triggers="clr-namespace:YcyzClass.Models.Automation.Triggers"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:SignalTriggerSettingsControl}}">
        <TextBox Text="{Binding Settings.SignalName}"/>
    </Grid>
</ci:TriggerSettingsControlBase>
