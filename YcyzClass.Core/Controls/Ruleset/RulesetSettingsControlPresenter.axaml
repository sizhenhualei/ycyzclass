<UserControl 
    x:Class="YcyzClass.Core.Controls.Ruleset.RulesetSettingsControlPresenter"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:YcyzClass.Core.Controls.Ruleset"
    xmlns:controls="clr-namespace:YcyzClass.Core.Controls"
    xmlns:converters="clr-namespace:YcyzClass.Core.Abstractions.Converters"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:services="clr-namespace:YcyzClass.Core.Abstractions.Services">
    <ContentPresenter x:Name="RootContentPresenter"/>
</UserControl>
